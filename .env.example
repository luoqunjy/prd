# ============ 会话加密 ============
# 32+ 字符随机字符串，用于 cookie 加密
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ============ 超级管理员预置 ============
SUPER_ADMIN_PHONE=18888888888
SUPER_ADMIN_PASSWORD=change_me_on_first_deploy
# 秘密免登录 URL 的 token，访问 /admin-bypass?token=xxx 自动登录为超管
SUPER_ADMIN_BYPASS_TOKEN=generate_a_long_random_string

# ============ 存储（本地优先 → 生产切 R2） ============
# 留空即使用本地文件系统（./data/storage/）；生产环境填 R2 四个值
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=prototype-host
R2_ENDPOINT=

# ============ 元数据存储（本地 JSON → 生产切 Vercel KV） ============
# 留空用本地 data/db.json；生产填 Vercel KV 的连接信息
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ============ 预览域名 ============
# 当前使用路径模式：/p/[slug]/
# 未来升级子域名时再填（格式如 myapp.top，留空即走路径）
# PREVIEW_BASE_DOMAIN=
